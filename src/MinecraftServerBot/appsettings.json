{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning",
        "DSharpPlus": "Warning",
        "Polly": "Warning",
        "Quartz": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*",
  "Discord": {
    "Token": "",
    "GuildId": 0,
    "AllowedChannelId": 0,
    "AdminUserIds": [],
    "DmFromAdminsOnly": true
  },
  "McServer": {
    "Host": "",
    "RconPort": 25575,
    "QueryPort": 25565,
    "RconPassword": "",
    "RconConnectTimeoutMs": 5000,
    "RconCommandTimeoutMs": 5000
  },
  "Llm": {
    "Endpoint": "https://openrouter.ai/api/v1",
    "ApiKey": "",
    "Model": "deepseek/deepseek-v4-flash",
    "Temperature": 0.3,
    "MaxOutputTokens": 1024
  },
  "Conversation": {
    "MaxMessages": 100,
    "MaxAgeDays": 14
  },
  "Poller": {
    "IntervalSeconds": 10,
    "RconListOnPlayerCountChange": true
  },
  "Announcements": {
    "Enabled": false,
    "ServerUpDown": false,
    "PlayerJoinLeave": false,
    "AdminActions": false,
    "MentionRoleId": null
  },
  "Presence": {
    "Enabled": true,
    "OnlineFormat": "Playing {online}/{max}",
    "OfflineText": "Offline"
  },
  "Exec": {
    "Blocklist": [
      "^op\\b",
      "^deop\\b",
      "^ban",
      "^pardon",
      "^whitelist",
      "^stop\\b"
    ],
    "OutputCharLimit": 1900,
    "RateLimitPerMinute": 5
  },
  "Confirmation": {
    "TimeoutSeconds": 60
  },
  "Health": {
    "StrictMode": false
  },
  "Audit": {
    "RetentionDays": null
  },
  "OpenTelemetry": {
    "LangfuseEndpoint": null,
    "LangfusePublicKey": null,
    "LangfuseSecretKey": null
  },
  "ConnectionStrings": {
    "Database": "Data Source=data/mc-bot.db"
  }
}
