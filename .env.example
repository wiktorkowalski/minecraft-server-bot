# Discord Bot Token
# Create at https://discord.com/developers/applications
Discord__Token=

# Discord guild + channel scoping (numeric IDs)
Discord__GuildId=
Discord__AllowedChannelId=
# Comma-separated list of admin Discord user IDs
Discord__AdminUserIds=
# Optional: channel where a Fabric Discord-bridge mod mirrors MC chat. Leave empty to disable.
# Discord__McChatBridgeChannelId=

# Minecraft server connection (Hetzner)
McServer__Host=
McServer__RconPort=25575
McServer__QueryPort=25565
McServer__RconPassword=

# OpenRouter / LLM
# Get key from https://openrouter.ai/keys
Llm__ApiKey=
# Override the default model if desired (default: moonshotai/kimi-k2.6)
# Llm__Model=deepseek/deepseek-v4-flash
# Disable OpenRouter web_search + web_fetch server tools (default: true / enabled)
# Llm__EnableWebTools=false

# Langfuse (LLM observability) — optional
# Endpoint: e.g. http://langfuse:3000/api/public/otel/v1/traces
OpenTelemetry__LangfuseEndpoint=
OpenTelemetry__LangfusePublicKey=
OpenTelemetry__LangfuseSecretKey=
